# No config needed if you have Claude Code subscription!
# Just close Claude Code and run: npm start
# The OAuth token is read from ~/.claude/.credentials.json automatically.

# --- OR: Anthropic API key (console.anthropic.com) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# --- OR: z.ai proxy (https://z.ai/manage-apikey/apikey-list) ---
# ANTHROPIC_AUTH_TOKEN=your-z-ai-key
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# CLAUDE_MODEL=glm-4.7
